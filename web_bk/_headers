# Cloudflare Pages security + caching headers.
# Each header block applies to the path pattern above it.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin

# Long-cache only what is content-hashed or rarely changes.
# .css/.js use unhashed filenames so MUST revalidate often, otherwise a
# new HTML deploy pairs with stale CSS/JS in the CDN edge and breaks the
# page until cache expires.

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=300, must-revalidate

/*.js
  Cache-Control: public, max-age=300, must-revalidate

# robots / sitemap should refresh quickly so crawlers see updates.

/robots.txt
  Cache-Control: public, max-age=3600

/sitemap.xml
  Cache-Control: public, max-age=3600
